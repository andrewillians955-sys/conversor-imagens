# Apache: consolida /index.html na raiz (301). Ajuste RewriteBase se o site estiver em subpasta.
# Não adicione regras que redirecionem / de volta para /index.html — isso gera loop.

<IfModule mod_rewrite.c>
  RewriteEngine On
  # Descomente se o site estiver em subpasta (ex.: /conversor-imagens/):
  # RewriteBase /conversor-imagens/

  RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L]
</IfModule>
